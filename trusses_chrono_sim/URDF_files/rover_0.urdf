        	<geometry>
           	<box size="0.960 .160 .490" />
        	</geometry>
      		</collision>
		<inertial>
		<mass value="40" />
  		<inertia ixx="3.29" ixy="0" ixz="0" iyy="3.16" iyz="0" izz="6.27" />
		</inertial>
