  <joint name="body_to_arm0_turret_spirit0" type="continuous">
  	<parent link="body_spirit0" />
  	<child link="arm0_base_turret_spirit0" />
  	<axis xyz="0 0 1" />
  	<origin xyz=".2 0 0" rpy="0 0 0" />
  </joint>

  <joint name="arm0_base_to_turret_spirit0" type="continuous">
  	<parent link="arm0_base_turret_spirit0" />
  	<child link="arm0_base_spirit0" />
  	<axis xyz="0 1 0" />
  	<origin xyz="0 0 0" rpy="0 0 0" />
  </joint>
  
  <joint name="arm0_base_to_twist_spirit0" type="continuous">
