<?xml version="1.0" ?>

<robot name="rover">
	<link name="body">
		<collision group="default">
        	<origin rpy="0 0 0" xyz="0 0 0"/>
        	<geometry>
           	<box size="0.960 .160 .490"/>
        	</geometry>
      		</collision>
		<inertial>
		<mass value="40" />
  		<inertia ixx="3.29" ixy="0" ixz="0" iyy="3.16" iyz="0" izz="6.27" />
		</inertial>
  		<visual>
          	<origin rpy="0 0 0" xyz="0 0 0"/>
          	<geometry>
            	<box size="0.960 .160 .490"/>
          	</geometry>
			<material name="darkgray">
    			<color rgba="0.1 0.1 0.1 1.0"/>
  			</material>
  		</visual>
  	</link>


	<joint name="front_right_joint" type="continuous">
    	<parent link="body"/>
      	<child link="front_right_wheel"/>
      	<origin xyz=".404 0 .3" rpy="0 0 0"/>
      	<axis xyz="0 0 1"/>
	</joint>
	<link name="front_right_wheel">
		<collision group="default">
        	<origin rpy="0 0 0" xyz="0 0 0"/>
        	<geometry>
           	<cylinder length="0.076" radius="0.3"/>
        	</geometry>
      		</collision>
		<visual>
          	<origin rpy="0 0 0" xyz="0 0 0"/>
          	<geometry>
            	<cylinder length="0.076" radius="0.3"/>
          	</geometry>
  			<material name="silver">
    			<color rgba="0.3 0.3 0.3 1.0"/>
  			</material>
		</visual>
		<inertial>
      		<mass value="2"/>
      		<inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    		</inertial>
	</link>

	<joint name="front_left_joint" type="continuous">
    	<parent link="body"/>
      	<child link="front_left_wheel"/>
      	<origin xyz=".404 0 -.3" rpy="0 0 0"/>
      	<axis xyz="0 0 1"/>
	</joint>
	<link name="front_left_wheel">
		<collision group="default">
        	<origin rpy="0 0 0" xyz="0 0 0"/>
        	<geometry>
           	<cylinder length="0.076" radius="0.3"/>
        	</geometry>
      		</collision>
		<visual>
          	<origin rpy="0 0 0" xyz="0 0 0"/>
          	<geometry>
            	<cylinder length="0.076" radius="0.3"/>
          	</geometry>
   			<material name="silver">
    			<color rgba="0.3 0.3 0.3 1.0"/>
  			</material>
		</visual>
		<inertial>
      		<mass value="10"/>
      		<inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    		</inertial>
	</link>

	<joint name="back_right_joint" type="continuous">
    	<parent link="body"/>
      	<child link="back_right_wheel"/>
      	<origin xyz="-.404 0 .3" rpy="0 0 0"/>
      	<axis xyz="0 0 1"/>
	</joint>
	<link name="back_right_wheel">
		<collision group="default">
        	<origin rpy="0 0 0" xyz="0 0 0"/>
        	<geometry>
           	<cylinder length="0.076" radius="0.3"/>
        	</geometry>
      		</collision>
		<visual>
          	<origin rpy="0 0 0" xyz="0 0 0"/>
          	<geometry>
            	<cylinder length="0.076" radius="0.3"/>
          	</geometry>
  			<material name="silver">
    			<color rgba="0.3 0.3 0.3 1.0"/>
  			</material>
		</visual>
		<inertial>
      		<mass value="2"/>
      		<inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    		</inertial>
	</link>

	<joint name="back_left_joint" type="continuous">
    	<parent link="body"/>
      	<child link="back_left_wheel"/>
      	<origin xyz="-.404 0 -.3" rpy="0 0 0"/>
      	<axis xyz="0 0 1"/>
	</joint>
	<link name="back_left_wheel">
		<collision group="default">
        	<origin rpy="0 0 0" xyz="0 0 0"/>
        	<geometry>
           	<cylinder length="0.076" radius="0.3"/>
        	</geometry>
      		</collision>
		<visual>
          	<origin rpy="0 0 0" xyz="0 0 0"/>
          	<geometry>
            	<cylinder length="0.076" radius="0.3"/>
          	</geometry>
  			<material name="silver">
    			<color rgba="0.3 0.3 0.3 1.0"/>
  			</material>
		</visual>
		<inertial>
      		<mass value="2"/>
      		<inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    		</inertial>
	</link>

  	<joint name="probe_joint" type="prismatic">
		<parent link="body"/>
		<child link="probe"/>
		<origin xyz="0 0 0" rpy="-1.5707 0 0"/>
		<limit effort="1000" lower="-0.707" upper="0.707" velocity="300"/>
  	</joint>

	<link name="probe">
		<collision group="default">
        	<origin rpy="0 0 0" xyz="0 0 0"/>
        	<geometry>
           	<cylinder length=".4" radius="0.05"/>
        	</geometry>
      		</collision>
		<visual>
          	<origin rpy="0 0 0" xyz="0 0 0"/>
          	<geometry>
            	<cylinder length=".15" radius="0.05"/>
          	</geometry>
          	<material name="black">
              	<color rgba="0 0 0 1"/>
          	</material>
		</visual>
		<inertial>
      		<mass value="2"/>
      		<inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    		</inertial>
	</link>
</robot>
