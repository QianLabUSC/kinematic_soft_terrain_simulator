  	<origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <joint name="arm0_twist_to_extension_spirit0" type="prismatic">
  	<parent link="arm0_twist_spirit0" />
  	<child link="arm0_extension_spirit0" />
  	<origin xyz="0 0 -1.15" rpy="0 0 0" />
    <limit effort="1000" lower="-0.707" upper="0.707" velocity="300" />
  </joint>
  
  <joint name="arm0_extension_to_turret_spirit0" type="continuous">
